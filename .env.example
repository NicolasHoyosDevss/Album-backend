PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,https://album-front-two.vercel.app

# Supabase Auth. Use the public anon key, not the service role key.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Docker/local PostgreSQL.
# Inside Docker, DB_HOST must be the database service name, not localhost.
DB_HOST=database
DB_PORT=5432
DB_USER=album_user
DB_PASSWORD=album_password
DB_NAME=album_db

# Production/Supabase PostgreSQL alternative.
# If DATABASE_URL is set, it takes precedence over DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME.
DATABASE_URL=
DB_SSL=false
